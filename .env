# ─────────────────────────────────────────────────────────────
# Frontend (Vite) environment — LOCAL DEVELOPMENT
# Only VITE_* vars are exposed to the browser. Do NOT put backend secrets here.
# ─────────────────────────────────────────────────────────────

# API base URL.
#   Local dev: leave EMPTY — requests use "/api/v1/..." and the Vite proxy
#              forwards them to Django on :8000 (see vite.config.js).
#   Production (Vercel): set to your deployed backend origin, e.g.
#   VITE_API_URL=https://your-space.hf.space
VITE_API_URL=

# Google Maps key — no longer required (the map uses free OpenStreetMap now).
# Kept only if you ever switch back to Google Maps.
VITE_GOOGLE_MAPS_API_KEY=AIzaSyADeLSm5n2zxbGooVoS6zggXITfSjbBsfo
