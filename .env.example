# ─────────────────────────────────────────────────────────────
# Backend environment template.  Copy to `.env` for local dev, or set these
# as secrets on your host in production.  NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# ── Django ───────────────────────────────────────────────────
# Generate a fresh one:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
# Your backend host(s), comma-separated. On Hugging Face Spaces:
ALLOWED_HOSTS=your-space.hf.space

# ── Database (PostgreSQL) ────────────────────────────────────
# LOCAL (Docker):  POSTGRES_HOST=localhost  POSTGRES_PORT=5432  password=postgres
# SUPABASE: Project → Settings → Database → Connection info
#   Host:  db.<project-ref>.supabase.co   (or the pooler host on port 6543)
#   User:  postgres        DB:  postgres
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-supabase-db-password
POSTGRES_HOST=db.your-project-ref.supabase.co
POSTGRES_PORT=5432
POSTGRES_SSLMODE=require

# ── CORS / CSRF (deployed frontend origin) ───────────────────
# Your Vercel URL(s), comma-separated. Include custom domains if any.
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app

# ── Razorpay (optional; blank = demo mode) ───────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
