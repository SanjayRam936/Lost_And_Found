# Frontend (Vite) environment template. Copy to `.env`.
# Only VITE_* vars are exposed to the browser — never put secrets here.

# API base URL.
#   Local dev: leave EMPTY (uses the Vite proxy -> Django :8000).
#   Production: your deployed backend origin, e.g. https://your-space.hf.space
VITE_API_URL=

# Optional — only if you switch the map back to Google Maps (default is free OSM).
VITE_GOOGLE_MAPS_API_KEY=
